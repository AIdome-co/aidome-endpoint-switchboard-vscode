{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "typescript: watch",
      "type": "npm",
      "script": "watch",
      "problemMatcher": {
        "base": "$tsc-watch",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting compilation in watch mode\\.\\.\\.$",
          "endsPattern": ".*Watching for file changes\\.$"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "group": "build"
    },
    {
      "type": "npm",
      "script": "lint",
      "problemMatcher": "$eslint-stylish"
    },
    {
      "type": "npm",
      "script": "test",
      "problemMatcher": []
    }
  ]
}
