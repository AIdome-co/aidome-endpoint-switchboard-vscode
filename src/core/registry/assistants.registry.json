{
  "$schemaVersion": "0.1.0",
  "updatedAt": "2026-03-23",
  "dialectCatalog": {
    "openai.chat_completions": "OpenAI-style /v1/chat/completions",
    "openai.responses": "OpenAI-style /v1/responses",
    "anthropic.messages": "Anthropic-style /v1/messages",
    "google.gemini.generate_content": "Google Gemini-style generateContent (varies by API surface)",
    "github.copilot": "GitHub Copilot — routable via proxy override (debug.overrideProxyUrl in github.copilot.advanced)",
    "tabnine.proprietary": "Tabnine proprietary protocol to Tabnine cloud/enterprise server"
  },
  "assistants": [
    {
      "key": "github-copilot",
      "displayName": "GitHub Copilot",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "GitHub.copilot",
          "GitHub.copilot-chat"
        ]
      },
      "dialect": {
        "primary": "github.copilot",
        "alsoPossible": []
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "B",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
          "vscode-settings",
          "proxy-override"
        ],
        "settingKeyHints": [
          "github.copilot.advanced"
        ],
        "notes": [
          "Proxy Override: sets github.copilot.advanced.debug.overrideProxyUrl (maps to internal.completionsUrl in Copilot Chat source) to route ALL Copilot REST traffic — inline completions and chat — through the gateway.",
          "The debug.overrideProxyUrl key is a legacy internal setting confirmed in the official vscode-copilot-chat source (src/extension/completions-core/vscode-node/lib/src/config.ts). It is not a public API but is stable across current releases.",
          "There is no user-configurable settings.json key for registering a custom BYOK model in Copilot Chat. Custom model providers require the VS Code languageModelChatProviders contribution point, which is not configurable via workspace settings.",
          "Tier B rather than A because debug.overrideProxyUrl is an undocumented internal setting; users should be aware it may change in future Copilot releases."
        ]
      },
      "tlsVerification": {
        "support": "vscode-global",
        "settingHint": "http.proxyStrictSSL",
        "notes": "Copilot inherits VS Code's http.proxyStrictSSL setting. No extension-specific TLS toggle."
      },
      "sources": [
        "https://marketplace.visualstudio.com/items?itemName=GitHub.copilot",
        "https://marketplace.visualstudio.com/items?itemName=GitHub.copilot-chat"
      ]
    },
    {
      "key": "cline",
      "displayName": "Cline",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "saoudrizwan.claude-dev"
        ]
      },
      "dialect": {
        "primary": "openai.chat_completions",
        "alsoPossible": [
          "openai.responses",
          "anthropic.messages",
          "google.gemini.generate_content"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "A",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
          "in-extension-ui",
          "vscode-settings-scan"
        ],
        "settingKeyHints": [
          "cline.*baseUrl*",
          "cline.*openai*base*",
          "cline.*openaiCompatible*"
        ],
        "notes": [
          "Cline supports 'OpenAI Compatible' and also supports a Base URL for OpenAI provider.",
          "Implementation should treat exact setting keys as discoverable by scanning contributes.configuration at runtime."
        ]
      },
      "tlsVerification": {
        "support": "vscode-global",
        "settingHint": "http.proxyStrictSSL",
        "notes": "Cline relies on VS Code's http.proxyStrictSSL. No extension-specific TLS toggle."
      },
      "sources": [
        "https://marketplace.visualstudio.com/items?itemName=saoudrizwan.claude-dev",
        "https://docs.cline.bot/configuration/api-providers/openai"
      ]
    },
    {
      "key": "roo-code",
      "displayName": "Roo Code",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "RooVeterinaryInc.roo-cline"
        ]
      },
      "dialect": {
        "primary": "openai.chat_completions",
        "alsoPossible": [
          "openai.responses",
          "anthropic.messages",
          "google.gemini.generate_content"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "A",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
          "vscode-settings",
          "in-extension-ui"
        ],
        "settingKeyHints": [
          "roo-cline.apiProvider",
          "roo-cline.openAiBaseUrl",
          "roo-cline.openAiModelId",
          "roo-cline.useOpenRouter",
          "roo-cline.anthropicApiKey",
          "roo-cline.geminiApiKey"
        ],
        "notes": [
          "Roo Code is a fork-family of the Cline-style agent and exposes explicit VS Code settings keys.",
          "Exact keys may evolve; keep a scan-and-verify path."
        ]
      },
      "tlsVerification": {
        "support": "vscode-global",
        "settingHint": "http.proxyStrictSSL",
        "notes": "Roo Code relies on VS Code's http.proxyStrictSSL. No extension-specific TLS toggle."
      },
      "sources": [
        "https://marketplace.visualstudio.com/items?itemName=RooVeterinaryInc.roo-cline",
        "https://docs.roocode.com/features/api-configuration",
        "https://docs.roocode.com/features/llm-apis/openai"
      ]
    },
    {
      "key": "kilo-code",
      "displayName": "Kilo Code",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "kilocode.kilo-code"
        ]
      },
      "dialect": {
        "primary": "openai.chat_completions",
        "alsoPossible": [
          "openai.responses",
          "anthropic.messages",
          "google.gemini.generate_content"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "A",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
          "vscode-settings",
          "in-extension-ui"
        ],
        "settingKeyHints": [
          "kilocode.apiProvider",
          "kilocode.openaiApiKey",
          "kilocode.openaiBaseUrl",
          "kilocode.openaiModel",
          "kilocode.useOpenRouter",
          "kilocode.customProviderEndpoint"
        ],
        "notes": [
          "Kilo Code supports OpenAI Base URL config.",
          "Treat settings keys as hints; confirm via contributes.configuration in the installed extension."
        ]
      },
      "tlsVerification": {
        "support": "vscode-global",
        "settingHint": "http.proxyStrictSSL",
        "notes": "No extension-specific TLS setting. Inherits VS Code's http.proxyStrictSSL."
      },
      "sources": [
        "https://docs.naga.ac/kilo-code/extension-settings",
        "https://docs.naga.ac/kilo-code/using-openai"
      ]
    },
    {
      "key": "continue",
      "displayName": "Continue.dev",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "Continue.continue"
        ]
      },
      "dialect": {
        "primary": "openai.chat_completions",
        "alsoPossible": [
          "openai.responses",
          "anthropic.messages",
          "google.gemini.generate_content"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "A",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
          "config-file",
          "guided"
        ],
        "configFileHints": [
          {
            "path": "~/.continue/config.yaml",
            "format": "yaml",
            "fields": [
              "models[].provider",
              "models[].apiBase",
              "models[].apiKey",
              "embeddings.provider",
              "embeddings.apiBase"
            ]
          }
        ],
        "notes": [
          "Continue uses a user config file where OpenAI's base can be set via apiBase.",
          "Your extension should back up the file and edit via YAML-aware tooling."
        ]
      },
      "tlsVerification": {
        "support": "native",
        "settingHint": "requestOptions.rejectUnauthorized (config.json); pending for config.yaml",
        "notes": "Continue supports requestOptions.rejectUnauthorized in legacy config.json per-model. The newer config.yaml does not yet support this field; an upstream feature request is open."
      },
      "sources": [
        "https://docs.continue.dev/customize/model-providers/more/openai-compatible"
      ]
    },
    {
      "key": "claude-code",
      "displayName": "Claude Code",
      "kind": "vscode-extension+cli",
      "detection": {
        "vscodeExtensionIds": [
          "anthropic.claude-code"
        ],
        "cliCommands": [
          "claude"
        ]
      },
      "dialect": {
        "primary": "anthropic.messages",
        "alsoPossible": [
          "openai.chat_completions"
        ]
      },
      "endpointSwitching": {
        "supported": "partially",
        "tier": "C",
        "preferredGatewayFrontDoor": "anthropic.messages",
        "configurationModes": [
          "env-vars",
          "guided"
        ],
        "envVarHints": [
          "ANTHROPIC_API_KEY",
          "HTTPS_PROXY",
          "HTTP_PROXY"
        ],
        "notes": [
          "Official docs do NOT clearly document an Anthropic 'BASE_URL' override.",
          "If AIdome ever offers an explicit forward-proxy mode, HTTPS_PROXY becomes a viable routing lever."
        ]
      },
      "tlsVerification": {
        "support": "env-var",
        "settingHint": "ANTHROPIC_DISABLE_TLS_VERIFY=true",
        "notes": "Claude Code supports ANTHROPIC_DISABLE_TLS_VERIFY env var to disable TLS verification. No config file setting."
      },
      "sources": [
        "https://marketplace.visualstudio.com/items?itemName=anthropic.claude-code",
        "https://docs.anthropic.com/en/docs/claude-code/settings"
      ]
    },
    {
      "key": "openai-codex",
      "displayName": "OpenAI Codex (CLI / IDE)",
      "kind": "cli",
      "detection": {
        "cliCommands": [
          "codex"
        ]
      },
      "dialect": {
        "primary": "openai.responses",
        "alsoPossible": [
          "openai.chat_completions"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "A",
        "preferredGatewayFrontDoor": "openai.responses",
        "configurationModes": [
          "config-file",
          "env-vars"
        ],
        "configFileHints": [
          {
            "path": "~/.codex/config.toml",
            "format": "toml",
            "fields": [
              "model_provider",
              "model",
              "providers.<name>.base_url",
              "providers.<name>.api_key",
              "providers.<name>.wire_api"
            ]
          }
        ],
        "envVarHints": [
          "OPENAI_API_KEY",
          "OPENAI_BASE_URL"
        ],
        "notes": [
          "Codex supports provider base_url and 'wire_api' (responses vs chat).",
          "For AIdome: implement OpenAI-compatible Responses API for best fidelity."
        ]
      },
      "tlsVerification": {
        "support": "env-var",
        "settingHint": "CODEX_CA_CERTIFICATE or SSL_CERT_FILE (custom CA only; no disable toggle)",
        "notes": "Codex CLI supports custom CA bundles via CODEX_CA_CERTIFICATE > SSL_CERT_FILE > system certs. There is no documented flag to disable TLS verification entirely."
      },
      "sources": [
        "https://github.com/openai/codex"
      ]
    },
    {
      "key": "gemini-cli",
      "displayName": "Gemini CLI",
      "kind": "cli",
      "detection": {
        "cliCommands": [
          "gemini"
        ]
      },
      "dialect": {
        "primary": "google.gemini.generate_content",
        "alsoPossible": [
          "openai.chat_completions"
        ]
      },
      "endpointSwitching": {
        "supported": false,
        "tier": "C",
        "configurationModes": [
          "guided-only"
        ],
        "notes": [
          "Official Gemini CLI does not present a general 'base_url' override.",
          "Prefer tools that support OpenAI-compatible endpoints and let AIdome talk to Gemini upstream."
        ]
      },
      "tlsVerification": {
        "support": "none",
        "notes": "Gemini CLI has no documented mechanism to disable TLS verification or supply custom CA certificates."
      },
      "sources": [
        "https://github.com/google-gemini/gemini-cli"
      ]
    },
    {
      "key": "codegpt",
      "displayName": "CodeGPT",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "CodeGPT.codegpt"
        ]
      },
      "dialect": {
        "primary": "openai.chat_completions",
        "alsoPossible": [
          "openai.responses",
          "anthropic.messages",
          "google.gemini.generate_content"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "B",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
