      ]
    },
    {
      "key": "anythingllm",
      "displayName": "AnythingLLM",
      "kind": "desktop-app",
      "detection": {
        "notes": [
          "Not a VS Code assistant extension; treat as external app with setup guidance."
        ]
      },
      "dialect": {
        "primary": "openai.chat_completions",
        "alsoPossible": [
          "openai.responses"
        ]
      },
      "endpointSwitching": {
        "supported": true,
        "tier": "B",
        "preferredGatewayFrontDoor": "openai.chat_completions",
        "configurationModes": [
          "guided"
        ],
        "notes": [
          "AnythingLLM supports a 'Generic OpenAI' provider pattern for OpenAI-compatible gateways via Base URL.",
