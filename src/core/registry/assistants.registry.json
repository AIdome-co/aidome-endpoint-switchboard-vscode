      },
      "sources": [
        "https://docs.anythingllm.com/setup/llm-configuration/cloud/openai"
      ]
    },
    {
      "key": "tabnine",
      "displayName": "Tabnine",
      "kind": "vscode-extension",
      "detection": {
        "vscodeExtensionIds": [
          "TabNine.tabnine-vscode"
        ]
      },
      "dialect": {
        "primary": "tabnine.proprietary",
        "alsoPossible": []
      },
      "endpointSwitching": {
        "supported": "enterprise-server-only",
        "tier": "C",
        "configurationModes": [
          "in-extension-ui",
          "guided"
        ],
        "notes": [
          "Tabnine can be pointed to a Tabnine Enterprise Server URL, not an OpenAI-compatible 'base_url' switch.",
          "Unless AIdome emulates Tabnine Enterprise protocol, treat as: detect + explain + guide."
        ]
      },
      "tlsVerification": {
        "support": "vscode-global",
        "settingHint": "http.proxyStrictSSL / NODE_EXTRA_CA_CERTS",
        "notes": "Tabnine has no extension-specific TLS toggle. Relies on VS Code's http.proxyStrictSSL and NODE_EXTRA_CA_CERTS for custom CA trust."
      },
      "sources": [
        "https://marketplace.visualstudio.com/items?itemName=TabNine.tabnine-vscode"
      ]
    }
  ]
}
